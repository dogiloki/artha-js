{
  "name": "@dogiloki/artha-js",
  "version": "4.0.0",
  "description": "Mini libreria de Web Components, XHR y UI para interfaces reactivas",
  "type": "module",
  "main": "./dist/artha.min.js",
  "module": "./dist/artha.min.js",
  "style": "./dist/artha.min.css",
  "exports": {
    ".": "./dist/artha.min.js",
    "./style": "./dist/artha.min.css",
    "./artha.min.js": "./dist/artha.min.js",
    "./artha.min.css": "./dist/artha.min.css"
  },
  "files": [
    "CHANGELOG.md",
    "README.md",
    "dist"
  ],
  "scripts": {
    "dev:css": "sass --watch src/scss/main.scss:dist/artha.min.css --style=expanded --source-map",
    "dev:js": "esbuild src/index.js --bundle --format=esm --outfile=dist/artha.js --sourcemap --watch",
    "dev:server": "live-server --watch=. --port=8080",
    "dev": "concurrently \"npm run dev:css\" \"npm run dev:js\" \"npm run dev:server\"",

    "build:css": "sass src/scss/main.scss dist/artha.min.css --style=compressed",
    "build:js": "esbuild src/index.js --bundle --format=esm --minify --outfile=dist/artha.min.js",
    "build": "npm run build:css && npm run build:js",

    "build:debug:css": "sass src/scss/main.scss dist/artha.css --style=expanded --source-map",
    "build:debug:js": "esbuild src/index.js --bundle --format=esm --outfile=dist/artha.js --sourcemap",
    "build:debug": "npm run build:debug:css && npm run build:debug:js"
  },
  "keywords": [
    "task-queue",
    "javascript",
    "notifications",
    "ui",
    "web-components",
    "laravel"
  ],
  "author": "dogiloki",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dogiloki/artha-js.git"
  },
  "bugs": {
    "url": "https://github.com/dogiloki/artha-js/issues"
  },
  "homepage": "https://github.com/dogiloki/artha-js#readme",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "esbuild": "^0.25.0",
    "live-server": "^1.2.2",
    "sass": "^1.98.0"
  }
}
